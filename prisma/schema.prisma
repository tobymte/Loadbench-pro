// LoadBench Pro — Prisma schema
// Safety-first reloading notebook. This schema records what the user does and
// what published source they cite — it does NOT compute or recommend loads.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================================================
// Identity & workspaces
// =============================================================================

model User {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  email       String   @unique
  displayName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships     WorkspaceMember[]
  ownedWorkspaces Workspace[]       @relation("WorkspaceOwner")
  auditEvents     AuditEvent[]
  importBatches   ImportBatch[]
  printJobs       PrintJob[]
  fileObjects     FileObject[]
  betaFeedbackIssues BetaFeedbackIssue[] @relation("BetaFeedbackReporter")
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner                     User                       @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members                   WorkspaceMember[]
  cartridges                Cartridge[]
  components                Component[]
  rifles                    Rifle[]
  sources                   Source[]
  loads                     Load[]
  sessions                  RangeSession[]
  auditEvents               AuditEvent[]
  importBatches             ImportBatch[]
  printJobs                 PrintJob[]
  fileObjects               FileObject[]
  pressureModelVersions     PressureModelVersion[]
  pressureEngineRuns        PressureEngineRun[]
  pressureValidationRecords PressureValidationRecord[]
  caseCapacityMeasurements  CaseCapacityMeasurement[]
  bulletDimensionRecords    BulletDimensionRecord[]
  powderMetadataRecords     PowderMetadataRecord[]
  barrelGeometryRecords     BarrelGeometryRecord[]
  chronoCalibrationRecords  ChronoCalibrationRecord[]
  simulationRuns            SimulationRun[]
  publishedDataImports      PublishedDataImport[]
  publishedLoadRowDrafts    PublishedLoadRowDraft[]
  entitlements              WorkspaceEntitlement[]
  modelValidationDatasets   ModelValidationDataset[]
  modelValidationCases      ModelValidationCase[]
  modelValidationRuns       ModelValidationRun[]
  betaFeedbackIssues        BetaFeedbackIssue[]

  @@index([ownerId])
}

// =============================================================================
// Billing entitlements (BigCommerce — Stripe fields retained for backward
// compatibility while the migration is in flight)
// =============================================================================
//
// WorkspaceEntitlement tracks paid-access state for premium feature keys
// (e.g. "pressure_modeling") on a per-workspace basis. This table is the
// single source of truth for gating premium UI; the BigCommerce order
// webhook updates rows here in response to paid-order events.
//
// Nothing in this table changes load validation behaviour. Premium access
// only unlocks UI surfaces — it does not authorize pressure predictions,
// charge recommendations, or any safety verdict.

enum EntitlementStatus {
  INACTIVE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  UNPAID
  PAUSED
}

model WorkspaceEntitlement {
  id                   String            @id @default(cuid())
  workspaceId          String
  // Logical feature key (e.g. "pressure_modeling"). Multiple entitlements
  // per workspace are possible if more premium features are added later.
  featureKey           String
  status               EntitlementStatus @default(INACTIVE)
  // Legacy Stripe identifiers — retained so existing rows are preserved
  // through the BigCommerce migration. New flows do not write these.
  stripeCustomerId     String?
  stripeSubscriptionId String?           @unique
  stripePriceId        String?
  // BigCommerce identifiers for the active checkout / order flow. All
  // optional because rows may exist before any BigCommerce interaction.
  bigcommerceOrderId    String?           @unique
  bigcommerceCartId     String?
  bigcommerceCustomerId String?
  bigcommerceCustomerEmail String?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean           @default(false)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, featureKey])
  @@index([stripeCustomerId])
  @@index([bigcommerceCustomerId])
  @@index([bigcommerceCustomerEmail])
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

// =============================================================================
// Reference data
// =============================================================================

model Cartridge {
  id                String   @id @default(cuid())
  workspaceId       String
  // Common reference fields. Stored as user inputs against published references.
  name              String // e.g. "6.5 Creedmoor"
  saami             String? // SAAMI / CIP designation if known
  caseCapacityGrH2O Float? // water grains, optional
  maxPressurePsi    Int? // published MAP, optional
  bulletDiameterIn  Float? // e.g. 0.264
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace                Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  loads                    Load[]
  rifles                   Rifle[]
  caseCapacityMeasurements CaseCapacityMeasurement[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

enum ComponentKind {
  BULLET
  POWDER
  PRIMER
  CASE
}

model Component {
  id                String        @id @default(cuid())
  workspaceId       String
  kind              ComponentKind
  manufacturer      String
  model             String
  // BULLET-specific
  bulletWeightGr    Float?
  bulletBc          Float?
  // POWDER-specific
  burnRateLabel     String? // user-entered, e.g. "H4350"
  // shared
  lotNumber         String?
  // Inventory recordkeeping fields. These are user-entered estimates only;
  // LoadBench Pro does not infer or recommend physical stock levels.
  quantityOnHand    Float?
  unit              String? // e.g. "ct" (bullets/primers/cases), "lb" or "gr" (powder)
  lowStockThreshold Float?
  notes             String?
  archived          Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  workspace                Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  bulletLoads              Load[]                    @relation("LoadBullet")
  powderLoads              Load[]                    @relation("LoadPowder")
  primerLoads              Load[]                    @relation("LoadPrimer")
  caseLoads                Load[]                    @relation("LoadCase")
  caseCapacityMeasurements CaseCapacityMeasurement[] @relation("BrassComponent")
  bulletDimensionRecords   BulletDimensionRecord[]
  powderMetadataRecords    PowderMetadataRecord[]

  @@index([workspaceId, kind])
}

model Rifle {
  id             String   @id @default(cuid())
  workspaceId    String
  name           String
  manufacturer   String?
  model          String?
  cartridgeId    String?
  barrelLengthIn Float?
  twistRate      String? // "1:8"
  opticNotes     String?
  zeroDistanceYd Float?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace             Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  cartridge             Cartridge?             @relation(fields: [cartridgeId], references: [id], onDelete: SetNull)
  sessions              RangeSession[]
  loads                 Load[]
  barrelGeometryRecords BarrelGeometryRecord[]

  @@index([workspaceId])
}

// Published reference source — manual, manufacturer data, etc.
model Source {
  id             String   @id @default(cuid())
  workspaceId    String
  title          String
  publisher      String? // e.g. "Hodgdon", "Sierra"
  edition        String?
  publishedYear  Int?
  url            String?
  // Pages or sections cited from the source.
  citation       String?
  // The published max charge captured from this source for the referenced
  // bullet/powder/primer/cartridge combination, used for validation.
  publishedMaxGr Float?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace             Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  loads                 Load[]
  validationRecords     PressureValidationRecord[]
  powderMetadataRecords PowderMetadataRecord[]
  publishedDataImports  PublishedDataImport[]
  publishedLoadRowDrafts PublishedLoadRowDraft[]

  @@index([workspaceId])
}

// =============================================================================
// Loads — the heart of the notebook
// =============================================================================

enum LoadStatus {
  DRAFT
  PLANNED
  LOADED
  TESTED
  ARCHIVED
}

model Load {
  id          String  @id @default(cuid())
  workspaceId String
  // Required references
  cartridgeId String
  bulletId    String
  powderId    String
  primerId    String?
  caseId      String?
  rifleId     String?
  // Citation to a published source (required for charge-bearing saves;
  // enforced in `lib/validation/load.ts`, not at the DB layer, so drafts
  // can be saved without a source).
  sourceId    String?

  name   String
  status LoadStatus @default(DRAFT)

  // Safety-relevant fields
  chargeGr               Float? // powder charge in grains
  cartridgeOalIn         Float? // overall length
  cartridgeBaseToOgiveIn Float?
  caseTrimLengthIn       Float?
  neckTensionThou        Float? // .001"
  // Row-specific published maximum charge captured from a verified
  // PublishedLoadRowDraft. When set, validateLoad uses this in preference to
  // Source.publishedMaxGr because source-level max is too coarse for tables
  // with per-bullet/per-powder published maxima.
  publishedMaxChargeGr   Float?
  // Optional reference back to the verified published row this Load was
  // created from. Free-form citation context (page label) is captured in
  // sourcePageLabel rather than stuffed into notes.
  publishedDataRowId     String?
  sourcePageLabel        String?
  // The user must explicitly check this before saving a charge-bearing load.
  safetyAcknowledged     Boolean @default(false)
  // Free-form note for safety context (e.g. "starting load, working up").
  safetyNotes            String?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Audit
  createdById String?
  updatedById String?

  workspace                Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  cartridge                Cartridge                  @relation(fields: [cartridgeId], references: [id])
  bullet                   Component                  @relation("LoadBullet", fields: [bulletId], references: [id])
  powder                   Component                  @relation("LoadPowder", fields: [powderId], references: [id])
  primer                   Component?                 @relation("LoadPrimer", fields: [primerId], references: [id])
  case_                    Component?                 @relation("LoadCase", fields: [caseId], references: [id])
  rifle                    Rifle?                     @relation(fields: [rifleId], references: [id], onDelete: SetNull)
  source                   Source?                    @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  publishedDataRow         PublishedLoadRowDraft?     @relation("LoadPublishedRow", fields: [publishedDataRowId], references: [id], onDelete: SetNull)
  sessions                 RangeSession[]
  validationRecords        PressureValidationRecord[]
  caseCapacityMeasurements CaseCapacityMeasurement[]
  chronoCalibrationRecords ChronoCalibrationRecord[]  @relation("ChronoCalRefLoad")
  simulationRuns           SimulationRun[]
  engineRuns               PressureEngineRun[]        @relation("EngineRunLoad")

  @@index([workspaceId, status])
  @@index([cartridgeId])
}

// =============================================================================
// Range sessions
// =============================================================================

model RangeSession {
  id              String   @id @default(cuid())
  workspaceId     String
  loadId          String?
  rifleId         String?
  date            DateTime @default(now())
  location        String?
  tempF           Float?
  humidityPct     Float?
  pressureInHg    Float?
  windMph         Float?
  // Group / chrono summary fields, optional
  shotsFired      Int?
  avgVelocityFps  Float?
  esFps           Float?
  sdFps           Float?
  groupSizeIn     Float?
  groupDistanceYd Float?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  load           Load?           @relation(fields: [loadId], references: [id], onDelete: SetNull)
  rifle          Rifle?          @relation(fields: [rifleId], references: [id], onDelete: SetNull)
  simulationRuns SimulationRun[]
  engineRuns     PressureEngineRun[] @relation("EngineRunSession")

  @@index([workspaceId])
}

// =============================================================================
// Audit & supporting tables
// =============================================================================

model AuditEvent {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String?
  entityType  String // "Load", "Component", ...
  entityId    String
  action      String // "create" | "update" | "delete" | "export" | "print"
  // JSON-encoded snapshot or diff. Stored as String so it can be read on any
  // Postgres provider without `Json` quirks; consumers can JSON.parse it.
  payload     String?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, entityType, entityId])
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model ImportBatch {
  id          String       @id @default(cuid())
  workspaceId String
  userId      String?
  source      String // file name or origin label
  entityType  String // "Load", "Component", ...
  status      ImportStatus @default(PENDING)
  totalRows   Int          @default(0)
  errorRows   Int          @default(0)
  createdAt   DateTime     @default(now())
  completedAt DateTime?

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  rows      ImportBatchRow[]

  @@index([workspaceId])
}

model ImportBatchRow {
  id       String  @id @default(cuid())
  batchId  String
  rowIndex Int
  raw      String // JSON-encoded raw row
  error    String?
  imported Boolean @default(false)

  batch ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
}

enum PrintJobStatus {
  QUEUED
  RENDERED
  PRINTED
  FAILED
}

model PrintJob {
  id          String         @id @default(cuid())
  workspaceId String
  userId      String?
  kind        String // "load-card" | "session-report" | "label"
  payload     String // JSON-encoded snapshot of what was printed
  status      PrintJobStatus @default(QUEUED)
  createdAt   DateTime       @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

model FileObject {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String?
  // Storage backend reference — we don't store the file here, just metadata.
  storageKey  String
  bucket      String?
  filename    String
  contentType String
  byteSize    Int
  // Optional link back to the entity that owns this file.
  entityType  String?
  entityId    String?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

// =============================================================================
// Pressure modeling — EXPERIMENTAL VALIDATION INFRASTRUCTURE ONLY.
// These tables exist so the team can record what a future, expert-validated
// internal-ballistics model would have to ingest, and to capture reference
// data (published or lab-measured) against which a future solver could be
// checked. NOTHING in this app computes pressure from these rows. The fields
// are stores, not formulas.
// =============================================================================

enum PressureModelStatus {
  DRAFT
  READY_FOR_EXPERT_REVIEW
  BLOCKED
  VALIDATED_REFERENCE
  REJECTED
}

model PressureModelVersion {
  id          String              @id @default(cuid())
  workspaceId String
  name        String
  description String?
  status      PressureModelStatus @default(DRAFT)
  notes       String?
  // Governance metadata: explicit operational status of this model identity.
  // Values are validated server-side. Any value other than DISABLED keeps the
  // engine in non-operational mode (the runner never produces pressure
  // predictions regardless of governance state — this column drives display
  // and audit only).
  governanceStatus    String? // 'draft' | 'validation_only' | 'disabled' | 'retired'
  blockedOutputsPolicy String? // Free-form policy text: what the model is forbidden from emitting.
  validationNotes     String? // Free-form notes about the validation status / progress.
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  workspace         Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  validationRecords PressureValidationRecord[]
  simulationRuns    SimulationRun[]
  engineRuns        PressureEngineRun[]

  @@index([workspaceId])
}

// =============================================================================
// Pressure engine — NON-OPERATIONAL SHELL.
// PressureEngineRun records an audit of a structured request to evaluate a
// candidate pressure model against user-entered solver inputs and chrono /
// reference observations. The runner intentionally produces no pressure
// estimate, no charge recommendation, and no safe/unsafe verdict. It records
// data completeness, missing-field bookkeeping, source coverage, and (where
// available) reference-vs-observed velocity deltas. Every row carries an
// explicit `pressurePredictionStatus = 'disabled'` so historical audit can
// confirm the engine has never been operational.
// =============================================================================

enum PressureEngineRunStatus {
  DRAFT
  INPUT_INCOMPLETE
  COMPLETED_NON_OPERATIONAL
  REJECTED_BY_GUARDRAIL
  ARCHIVED
}

model PressureEngineRun {
  id                  String                  @id @default(cuid())
  workspaceId         String
  modelVersionId      String?
  loadId              String?
  rangeSessionId      String?
  validationRecordId  String?
  status              PressureEngineRunStatus @default(DRAFT)
  // Always 'disabled' for any row this app writes. Persisted so the audit
  // trail proves no run ever produced a pressure estimate. Stored as a
  // string column so future, expert-reviewed model integrations could add
  // additional non-pressure status labels without a destructive migration.
  pressurePredictionStatus String                @default("disabled")
  // JSON-encoded snapshot of inputs at the moment of the run (linked
  // entities, solver-input record counts, chrono observations). String type
  // for Postgres-provider portability, matching the AuditEvent.payload and
  // SimulationRun.inputsSnapshotJson convention.
  inputsSnapshotJson  String?
  // JSON-encoded non-prescriptive outputs: data completeness score, missing
  // fields list, source coverage, velocity delta (if observable), input
  // consistency warnings. Intentionally contains no PSI / pressure estimate
  // / charge recommendation. The forbidden-key guardrail rejects any input
  // body that would imply otherwise before the row is written.
  outputsJson         String?
  // Echo of the velocity-only delta (if observable) for easy SQL queries
  // without parsing outputsJson. Velocity, never pressure.
  velocityDeltaFps    Float?
  velocityDeltaPct    Float?
  notes               String?
  // The caller must check this before the row is saved.
  acknowledgedExperimental Boolean              @default(false)
  createdById         String?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  workspace        Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  modelVersion     PressureModelVersion?      @relation(fields: [modelVersionId], references: [id], onDelete: SetNull)
  load             Load?                      @relation("EngineRunLoad", fields: [loadId], references: [id], onDelete: SetNull)
  rangeSession     RangeSession?              @relation("EngineRunSession", fields: [rangeSessionId], references: [id], onDelete: SetNull)
  validationRecord PressureValidationRecord?  @relation("EngineRunValidation", fields: [validationRecordId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([modelVersionId])
  @@index([loadId])
}

model PressureValidationRecord {
  id                   String              @id @default(cuid())
  workspaceId          String
  // Optional links to existing entities. Validation records can describe a
  // pure published-reference data point with no in-workspace load to attach.
  loadId               String?
  sourceId             String?
  modelVersionId       String?
  // Human-readable label for the dataset row — e.g. "Hodgdon 2024 H4350 140gr 6.5CM max".
  referenceLabel       String
  // User-entered reference values from a licensed/published source or lab
  // measurement. LoadBench Pro does not compute these. They are inputs to a
  // future calibration check, never outputs of one.
  referencePressurePsi Int?
  referenceVelocityFps Float?
  measuredVelocityFps  Float?
  // Free-form JSON-encoded environmental / setup conditions (string for
  // Postgres-provider portability, matches AuditEvent.payload convention).
  conditionsJson       String?
  status               PressureModelStatus @default(DRAFT)
  notes                String?
  // The user must check this acknowledgement before the row is saved.
  acknowledged         Boolean             @default(false)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  workspace      Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  load           Load?                 @relation(fields: [loadId], references: [id], onDelete: SetNull)
  source         Source?               @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  modelVersion   PressureModelVersion? @relation(fields: [modelVersionId], references: [id], onDelete: SetNull)
  simulationRuns SimulationRun[]
  engineRuns     PressureEngineRun[]   @relation("EngineRunValidation")

  @@index([workspaceId, status])
  @@index([loadId])
}

// =============================================================================
// Solver-input data capture — EXPERIMENTAL.
// These tables store user-entered measurements and metadata that a future,
// expert-validated internal-ballistics solver would need as inputs. NOTHING
// in this app computes pressure, recommends charges, or makes safe/unsafe
// claims from these rows. They are stores, not formulas.
// =============================================================================

model CaseCapacityMeasurement {
  id               String   @id @default(cuid())
  workspaceId      String
  cartridgeId      String?
  loadId           String?
  brassComponentId String?
  lotNumber        String?
  method           String? // e.g. "water-fill", "alcohol-fill"
  firedOrResized   String? // "fired" | "resized" | "new"
  waterCapacityGr  Float?
  sampleCount      Int?
  avgCapacityGr    Float?
  sdCapacityGr     Float?
  tempF            Float?
  notes            String?
  createdById      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace      Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  cartridge      Cartridge? @relation(fields: [cartridgeId], references: [id], onDelete: SetNull)
  load           Load?      @relation(fields: [loadId], references: [id], onDelete: SetNull)
  brassComponent Component? @relation("BrassComponent", fields: [brassComponentId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([cartridgeId])
  @@index([loadId])
}

model BulletDimensionRecord {
  id               String   @id @default(cuid())
  workspaceId      String
  componentId      String?
  manufacturer     String?
  model            String?
  lotNumber        String?
  weightGr         Float?
  diameterIn       Float?
  lengthIn         Float?
  bearingSurfaceIn Float?
  boatTailLengthIn Float?
  ogiveStyle       String?
  bcG1             Float?
  bcG7             Float?
  sampleCount      Int?
  notes            String?
  createdById      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  component Component? @relation(fields: [componentId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([componentId])
}

model PowderMetadataRecord {
  id                   String   @id @default(cuid())
  workspaceId          String
  componentId          String?
  manufacturer         String?
  powderName           String?
  lotNumber            String?
  burnRateLabel        String?
  densityGcc           Float?
  bulkDensityGrPerCc   Float?
  kernelShape          String?
  tempSensitivityNotes String?
  sourceId             String?
  notes                String?
  createdById          String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  component Component? @relation(fields: [componentId], references: [id], onDelete: SetNull)
  source    Source?    @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([componentId])
}

model BarrelGeometryRecord {
  id               String   @id @default(cuid())
  workspaceId      String
  rifleId          String?
  name             String?
  barrelLengthIn   Float?
  twistRate        String?
  boreDiameterIn   Float?
  grooveDiameterIn Float?
  chamberNotes     String?
  throatLengthIn   Float?
  freeboreIn       Float?
  landCount        Int?
  notes            String?
  createdById      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  rifle     Rifle?    @relation(fields: [rifleId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([rifleId])
}

model ChronoCalibrationRecord {
  id                   String    @id @default(cuid())
  workspaceId          String
  deviceName           String?
  deviceType           String?
  serialNumber         String?
  firmwareVersion      String?
  calibrationDate      DateTime?
  referenceLoadId      String?
  referenceVelocityFps Float?
  observedVelocityFps  Float?
  offsetFps            Float?
  conditionsJson       String?
  notes                String?
  createdById          String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  referenceLoad Load?     @relation("ChronoCalRefLoad", fields: [referenceLoadId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

// =============================================================================
// Simulation sandbox — NON-OPERATIONAL VALIDATION COMPARISON.
// A SimulationRun records the outcome of comparing a user-entered reference
// (or chrono session) against a placeholder PressureModelVersion. It stores
// review status and velocity-delta bookkeeping only. NOTHING in this app
// computes pressure predictions, recommends charges, or labels any load as
// safe or unsafe. There is intentionally no predictedPressurePsi or
// recommendedChargeGr field on this model.
// =============================================================================

enum SimulationRunStatus {
  DRAFT
  INPUT_INCOMPLETE
  READY_FOR_EXPERT_REVIEW
  REFERENCE_MATCHED_WITHIN_TOLERANCE
  NEEDS_INVESTIGATION
  REJECTED_BY_REVIEWER
}

model SimulationRun {
  id                  String              @id @default(cuid())
  workspaceId         String
  modelVersionId      String
  loadId              String?
  validationRecordId  String?
  rangeSessionId      String?
  // Optional link to a verified PublishedLoadRowDraft. When set, the row's
  // user-verified velocity / charge value can be used as the reference value
  // for the comparison. Reference pressure on a published row, if any, is
  // user-entered input from the cited document, never a computed prediction.
  publishedRowId      String?
  status              SimulationRunStatus @default(DRAFT)
  // Comparison bookkeeping — velocity only. Pressure prediction is intentionally
  // absent. Reference pressure (if any) lives on the linked PressureValidationRecord
  // and is treated strictly as user-entered input, never as a computed output.
  velocityDeltaFps    Float?
  velocityDeltaPct    Float?
  toleranceFps        Float?
  tolerancePct        Float?
  // JSON-encoded snapshot of inputs at the moment the run was created
  // (selected model version, reference source, observed source, tolerance,
  // any user-entered scalars). Stored as String for Postgres-provider
  // portability, matching AuditEvent.payload / conditionsJson convention.
  inputsSnapshotJson  String?
  // JSON-encoded computed comparison metrics: velocity delta (fps/%), absolute
  // value, within-tolerance booleans, range-session ES/SD echoed for display,
  // residual vs reference, data-completeness score, coverage label. Strictly
  // descriptive of user-entered inputs — no pressure prediction is encoded.
  metricsJson         String?
  notes               String?
  reviewerNotes       String?
  acknowledgedExperimental Boolean        @default(false)
  createdById         String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  workspace         Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  modelVersion      PressureModelVersion      @relation(fields: [modelVersionId], references: [id], onDelete: Cascade)
  load              Load?                     @relation(fields: [loadId], references: [id], onDelete: SetNull)
  validationRecord  PressureValidationRecord? @relation(fields: [validationRecordId], references: [id], onDelete: SetNull)
  rangeSession      RangeSession?             @relation(fields: [rangeSessionId], references: [id], onDelete: SetNull)
  publishedRow      PublishedLoadRowDraft?    @relation("SimulationPublishedRow", fields: [publishedRowId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([modelVersionId])
  @@index([loadId])
  @@index([publishedRowId])
}

// =============================================================================
// Published-data review/staging — NON-AUTHORITATIVE.
// PublishedDataImport and PublishedLoadRowDraft hold rows transcribed or
// pasted from manufacturer/published references for the user to verify
// against the original document before they ever drive a Load record.
// Rows here are NOT loads, are NOT recommendations, and are NOT presented
// as safe/unsafe. They live in a separate review surface until a verified
// row is used as a citation on a normal Load (which still goes through the
// existing safety acknowledgement validation in lib/validation/load.ts).
// =============================================================================

enum PublishedDataImportStatus {
  DRAFT
  IN_REVIEW
  ARCHIVED
}

enum PublishedLoadRowStatus {
  DRAFT
  NEEDS_REVIEW
  VERIFIED
  REJECTED
}

model PublishedDataImport {
  id          String                    @id @default(cuid())
  workspaceId String
  sourceId    String?
  title       String
  publisher   String?
  reference   String?
  notes       String?
  status      PublishedDataImportStatus @default(DRAFT)
  createdById String?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  workspace Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  source    Source?                  @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  rows      PublishedLoadRowDraft[]

  @@index([workspaceId, status])
}

model PublishedLoadRowDraft {
  id                 String                 @id @default(cuid())
  workspaceId        String
  importId           String
  sourceId           String?
  cartridgeId        String?
  bulletComponentId  String?
  powderComponentId  String?
  pageLabel          String?
  bulletWeightGr     Float?
  bulletName         String?
  powderName         String?
  chargeGr           Float?
  velocityFps        Float?
  isMaxLoad          Boolean                @default(false)
  // Row-specific published maximum charge for this transcribed row. Many
  // published tables list a per-row maximum (e.g. one bullet/powder pair has
  // a different max than the source-wide max). This is independent of
  // Source.publishedMaxGr and is the value validateLoad checks against when
  // a Load is created from this verified row.
  publishedMaxChargeGr Float?
  colIn              Float?
  bcG1               Float?
  bcG7               Float?
  status             PublishedLoadRowStatus @default(DRAFT)
  verifiedById       String?
  verifiedAt         DateTime?
  notes              String?
  sourceExcerptHash  String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  workspace      Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  import         PublishedDataImport  @relation(fields: [importId], references: [id], onDelete: Cascade)
  source         Source?              @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  loads          Load[]               @relation("LoadPublishedRow")
  simulationRuns SimulationRun[]      @relation("SimulationPublishedRow")

  @@index([workspaceId, status])
  @@index([importId])
}

// =============================================================================
// Model validation harness — admin-only, governance-first.
// These tables persist validation datasets, reference cases, and runs of an
// adapter against those cases. NOTHING here computes pressure. Every run row
// carries an explicit pressurePredictionStatus = 'disabled' (or another
// non-prescriptive label) so the audit trail can prove no predictions were
// produced. Reference pressure values, when stored on a case, are USER-
// ENTERED REFERENCE METADATA from a licensed source or a controlled lab —
// they are admin-only and never rendered as load guidance.
// =============================================================================

enum ModelValidationDatasetKind {
  PUBLISHED
  MANUFACTURER
  LAB
  INTERNAL_TEST
}

enum ModelValidationDatasetStatus {
  DRAFT
  IN_REVIEW
  APPROVED_PENDING_REVIEW
  ARCHIVED
}

enum ModelValidationRunStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED_NON_OPERATIONAL
  REJECTED_BY_GUARDRAIL
  ERRORED
  ARCHIVED
}

model ModelValidationDataset {
  id                       String                       @id @default(cuid())
  workspaceId              String
  name                     String
  kind                     ModelValidationDatasetKind   @default(PUBLISHED)
  description              String?
  // Reference identifier — DOI, manual page reference, lab report id, etc.
  referenceIdentifier      String?
  licenseNote              String?
  status                   ModelValidationDatasetStatus @default(DRAFT)
  // The admin must check this acknowledgement before the row is saved.
  acknowledgedValidationOnly Boolean                     @default(false)
  createdById              String?
  createdAt                DateTime                     @default(now())
  updatedAt                DateTime                     @updatedAt

  workspace Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  cases     ModelValidationCase[]
  runs      ModelValidationRun[]

  @@index([workspaceId, status])
}

model ModelValidationCase {
  id                  String   @id @default(cuid())
  workspaceId         String
  datasetId           String
  label               String
  cartridgeName       String?
  bulletWeightGr      Float?
  bulletDiameterIn    Float?
  chargeGr            Float?
  caseCapacityGrH2O   Float?
  barrelLengthIn      Float?
  twistRate           String?
  cartridgeOalIn      Float?
  powderBurnRateLabel String?
  tempF               Float?
  // Reference values transcribed from the dataset source. Velocity is
  // displayed; pressure is admin-only validation reference data and is
  // never rendered as guidance.
  referenceVelocityFps Float?
  referencePressurePsi Int?
  // Optional observed-velocity from a lab measurement, used for velocity
  // delta surfaced by the harness.
  observedVelocityFps  Float?
  pageLabel            String?
  notes                String?
  createdById          String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  workspace Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dataset   ModelValidationDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([datasetId])
}

model ModelValidationRun {
  id                  String                    @id @default(cuid())
  workspaceId         String
  datasetId           String
  // Adapter identity. Code-only registry — see lib/ballistics/modelAdapter.ts.
  adapterName         String
  adapterVersion      String?
  modelVersionId      String?
  status              ModelValidationRunStatus  @default(DRAFT)
  // Always one of the non-prescriptive labels. Persisted so the audit trail
  // can prove no run produced a pressure estimate.
  pressurePredictionStatus String                  @default("disabled")
  // JSON-encoded harness summary: total cases, completed cases, guardrail
  // rejections, mean velocity delta, etc. Stored as String for Postgres-
  // provider portability and to match AuditEvent.payload convention.
  summaryJson         String?
  // JSON-encoded per-case results.
  caseResultsJson     String?
  // If the run was rejected by the guardrail, the set of forbidden keys
  // observed across cases is captured here for quick SQL audit.
  rejectedForbiddenKeysJson String?
  notes               String?
  acknowledgedValidationOnly Boolean             @default(false)
  createdById         String?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  workspace Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dataset   ModelValidationDataset  @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([datasetId])
}

// =============================================================================
// Beta feedback & issue tracker.
// Captures user-submitted bug reports, usability feedback, feature requests,
// data/safety/performance/mobile/deployment issues during the beta. Stored on
// the workspace when one is available; both `workspaceId` and `reporterUserId`
// are optional so unauthenticated submissions (when LOADBENCH_DISABLE_AUTH
// fallback or a future anonymous channel is in use) are still captured.
//
// Safety boundary: a "safety concern" category is recorded as user-reported
// data only. This model does NOT process the report into advice, pressure
// estimates, charge recommendations, or safe/unsafe verdicts.
// =============================================================================

enum BetaFeedbackType {
  BUG
  USABILITY
  FEATURE_REQUEST
  DATA_ISSUE
  SAFETY_CONCERN
  PERFORMANCE
  MOBILE
  DEPLOYMENT
}

enum BetaFeedbackSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BetaFeedbackStatus {
  NEW
  TRIAGED
  IN_PROGRESS
  BLOCKED
  RESOLVED
  WONT_FIX
  ARCHIVED
}

model BetaFeedbackIssue {
  id                String                @id @default(cuid())
  // Workspace association — optional, so anonymous / pre-workspace submissions
  // are not rejected. Where present, scoping uses this column.
  workspaceId       String?
  // Reporter linkage — optional. When the submission is unauthenticated, we
  // still keep an email field for follow-up.
  reporterUserId    String?
  reporterEmail     String?
  reporterDisplay   String?

  title             String
  type              BetaFeedbackType      @default(BUG)
  severity          BetaFeedbackSeverity  @default(MEDIUM)
  status            BetaFeedbackStatus    @default(NEW)
  // Free-text label for the page/area the report concerns (e.g. "/loads",
  // "mobile nav", "chrono import"). Not an enum because pages evolve.
  pageArea          String?
  description       String
  stepsToReproduce  String?
  expectedResult    String?
  actualResult      String?
  deviceBrowser     String?
  // Contact preference: free text. ("email me back", "discord: handle", etc.)
  contactPreference String?
  // Optional admin/operator triage notes. Surfaces on /admin/beta/issues only.
  adminNotes        String?
  // Optional commit/build hash captured at submit time, if the user supplies it.
  buildHash         String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  workspace         Workspace?            @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  reporter          User?                 @relation("BetaFeedbackReporter", fields: [reporterUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([status])
  @@index([type])
  @@index([severity])
  @@index([createdAt])
}
