# =============================================================================
# LoadBench Pro — environment variables
# Copy to .env.local for local development. Never commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Postgres) — Neon, Supabase, Railway, or local Postgres
# -----------------------------------------------------------------------------
# Use the connection-pooled URL for the app (e.g. Neon pooled / Supabase pgbouncer).
DATABASE_URL="postgresql://user:password@host:5432/loadbench?schema=public"
# Direct, non-pooled URL used by Prisma Migrate. Required on Neon/Supabase.
DIRECT_URL="postgresql://user:password@host:5432/loadbench?schema=public"

# -----------------------------------------------------------------------------
# Clerk authentication — https://dashboard.clerk.com
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
# Optional redirect overrides
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="LoadBench Pro"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Feature flags (optional)
# -----------------------------------------------------------------------------
# When "true", auth middleware allows unauthenticated access to all routes.
# Use only for local development scaffolding before Clerk is wired up.
LOADBENCH_DISABLE_AUTH="true"

# Comma-separated list of Clerk-account emails authorised to use the
# /admin/entitlements page (manual grant/revoke of pressure_modeling while
# BigCommerce payments are not configured). Matched case-insensitively
# against the authenticated user's primary email. Leave blank in production
# to lock the admin UI. If LOADBENCH_DISABLE_AUTH=true, this var is ignored
# and the admin UI is reachable without Clerk — local dev only.
LOADBENCH_ADMIN_EMAILS=""

# -----------------------------------------------------------------------------
# BigCommerce — primary paid-access checkout for the premium
# pressure-modeling workspace. The user is redirected to BigCommerce's
# hosted "redirected checkout" so card details never touch this server.
# -----------------------------------------------------------------------------
# Store hash from your BigCommerce control panel. Settings → API accounts
# (also visible in any API URL as api.bigcommerce.com/stores/<HASH>/...).
BIGCOMMERCE_STORE_HASH=""
# Access token from a BigCommerce API account. Required scopes:
#   - Carts:           modify
#   - Checkouts:       modify
#   - Orders:          read-only
#   - Information & Settings: read-only
BIGCOMMERCE_ACCESS_TOKEN=""
# (Optional) Sales channel id if you sell on multiple channels. Leave
# blank to use the default storefront channel.
BIGCOMMERCE_CHANNEL_ID=""
# Numeric Product ID of the digital "Pressure Modeling Access" product
# in your BigCommerce catalog. Edit the product and read the numeric id
# from the URL (e.g. /manage/products/123 → 123).
BIGCOMMERCE_PRESSURE_PRODUCT_ID=""
# (Optional) Shared secret used to verify webhook signatures, when your
# BigCommerce webhook is configured with one. When set, the webhook
# handler rejects requests whose x-bc-webhook-signature header does not
# match an HMAC-SHA256 of the raw body using this secret.
BIGCOMMERCE_WEBHOOK_SECRET=""
# Alternative name for the same secret (some setups call it CLIENT_SECRET).
# Either var is honored; BIGCOMMERCE_WEBHOOK_SECRET takes precedence.
BIGCOMMERCE_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Stripe — LEGACY. Retained so existing Stripe-only deployments keep
# working at /api/billing/checkout, /api/billing/portal, /api/billing/webhook.
# The active UI uses BigCommerce; leave blank to disable Stripe entirely.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRESSURE_MODELING_PRICE_ID=""
