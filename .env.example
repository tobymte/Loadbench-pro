# =============================================================================
# LoadBench Pro — environment variables
# Copy to .env.local for local development. Never commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Postgres) — Neon, Supabase, Railway, or local Postgres
# -----------------------------------------------------------------------------
# Use the connection-pooled URL for the app (e.g. Neon pooled / Supabase pgbouncer).
DATABASE_URL="postgresql://user:password@host:5432/loadbench?schema=public"
# Direct, non-pooled URL used by Prisma Migrate. Required on Neon/Supabase.
DIRECT_URL="postgresql://user:password@host:5432/loadbench?schema=public"

# -----------------------------------------------------------------------------
# Clerk authentication — https://dashboard.clerk.com
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
# Optional redirect overrides
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="LoadBench Pro"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Feature flags (optional)
# -----------------------------------------------------------------------------
# When "true", auth middleware allows unauthenticated access to all routes.
# Use only for local development scaffolding before Clerk is wired up.
LOADBENCH_DISABLE_AUTH="true"

# -----------------------------------------------------------------------------
# Stripe — paid-access infrastructure for premium pressure-modeling surfaces
# -----------------------------------------------------------------------------
# Server-side Stripe secret. Keep secret; never expose to the client.
STRIPE_SECRET_KEY=""
# Webhook signing secret for /api/billing/webhook. Required for the webhook
# handler to accept Stripe events (checkout.session.completed,
# customer.subscription.created/updated/deleted).
STRIPE_WEBHOOK_SECRET=""
# Publishable key. Reserved for future client-side Stripe.js usage; the
# current implementation uses Stripe Hosted Checkout and does not require it.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Stripe Price ID (price_...) for the recurring pressure-modeling
# subscription. Create a Product + recurring Price in the Stripe dashboard,
# then paste its id here.
STRIPE_PRESSURE_MODELING_PRICE_ID=""
